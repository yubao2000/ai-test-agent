{
  "manifest_version": 3,
  "name": "AI Test Agent",
  "short_name": "AI Test",
  "version": "0.1.0",
  "description": "AI 驱动的浏览器自动化测试助手 — 安装即用，自然语言操控浏览器，自动执行测试用例。",
  "author": "yubao2000",
  "homepage_url": "https://github.com/yubao2000/ai-test-agent",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "tabs",
    "scripting",
    "debugger"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_title": "AI Test Agent — 打开侧面板",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
